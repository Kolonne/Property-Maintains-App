{
  "name": "property-maintains-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:apply": "node --env-file=.env.local scripts/apply-sql.mjs db/schema.sql",
